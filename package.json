    "markdown-it-highlightjs": "^2.0.0",
    "node-watch": "^0.7.0",
    "opn": "^4.0.2",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "simple-pandoc": "^0.1.0",
    "websocket": "^1.0.32",
    "yargs": "^6.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.3",
    "@babel/preset-env": "^7.12.1",
